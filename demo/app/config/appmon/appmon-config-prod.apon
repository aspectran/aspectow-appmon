# Polling configuration used only when WebSocket is not supported
pollingConfig: {
    # The interval in milliseconds at which the client polls the server for new messages
    pollingInterval: 3000
    # The duration in milliseconds after which an inactive polling session expires
    sessionTimeout: 30000
    # The initial capacity of the shared message buffer
    initialBufferSize: 9999
}
app: {
    id: root
    title: Root
    event: {
        id: activity
        target: root
        parameters: {
            +: /**
        }
    }
    event: {
        id: session
        target: tow.server/root
    }
    metric: {
        id: heap
        title: Heap
        description: Shows JVM Heap memory usage status
        reader: com.aspectran.aspectow.appmon.engine.exporter.metric.jvm.HeapMemoryUsageReader
        sampleInterval: 500
        heading: true
    }
    metric: {
        id: undertow-tp
        title: Undertow TP
        description: Metrics of Undertow thread pool resources
        reader: com.aspectran.aspectow.appmon.engine.exporter.metric.undertow.NioWorkerMetricsReader
        target: tow.server
        sampleInterval: 30
        exportInterval: 900
        heading: true
    }
    log: {
        id: app
        file: /logs/root.log
        sampleInterval: 300
        lastLines: 1000
    }
    log: {
        id: access
        file: /logs/root-access.log
        sampleInterval: 300
        lastLines: 1000
    }
}
app: {
    id: appmon
    title: AppMon
    event: {
        id: activity
        target: appmon
        parameters: {
            +: /**
            -: /nodes/**/appmon/polling/**  # Ignore polling requests
        }
    }
    event: {
        id: session
        target: tow.server/appmon
    }
    log: {
        id: app
        file: /logs/appmon.log
        sampleInterval: 300
        lastLines: 1000
    }
    log: {
        id: access
        file: /logs/appmon-access.log
        sampleInterval: 300
        lastLines: 1000
    }
}
app: {
    id: jpetstore
    title: JPetStore
    log: {
        id: app
        file: /logs/jpetstore.log
        sampleInterval: 300
        lastLines: 1000
    }
    log: {
        id: access
        file: /logs/jpetstore-access.log
        sampleInterval: 300
        lastLines: 1000
    }
}
app: {
    id: demo
    title: Demo
    log: {
        id: app
        file: /logs/demo.log
        sampleInterval: 300
        lastLines: 1000
    }
    log: {
        id: access
        file: /logs/demo-access.log
        sampleInterval: 300
        lastLines: 1000
    }
}